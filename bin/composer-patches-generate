#!/usr/bin/env php
<?php

declare(strict_types=1);

use FHaase\ComposerPatchesGenerate\Command\ComposerPatchesGenerateCommand;
use Symfony\Component\Console\Application;

$possibleAutoloadPaths = [
    __DIR__ . '/../autoload.php',
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../../vendor/autoload.php',
];

foreach ($possibleAutoloadPaths as $possibleAutoloadPath) {
    if (! file_exists($possibleAutoloadPath)) {
        continue;
    }

    require_once $possibleAutoloadPath;
}


$application = new Application('Composer Patches Commands', '1.0.0');
$addMethod = method_exists($application, 'addCommand') ? 'addCommand' : 'add';
$application->{$addMethod}(new ComposerPatchesGenerateCommand());
$application->setDefaultCommand('composer-patches:generate', true);
$statusCode = $application->run();
exit($statusCode);
